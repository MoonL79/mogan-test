#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib/mogan-cli"
SCHEME_SCRIPT="${SCRIPT_DIR}/../src/cli/mogan-cli.scm"
RUNTIME_SCRIPT="${SCRIPT_DIR}/../src/cli/runtime/client.scm"
SERVER_RUNTIME_SCRIPT="${SCRIPT_DIR}/../src/cli/runtime/mogan-server-runtime.scm"
MOGAN_ROOT="/home/mingshen/git/mogan"
CONNECT_TRACE="/tmp/mogan-test-connect-trace.log"
SERVER_TRACE="/tmp/mogan-test-server-trace.log"
RESULT_FILE="/tmp/mogan-test-runtime-result.txt"
RUNTIME_OUTPUT="/tmp/mogan-test-runtime-output.log"
TEXMACS_PATH_DIR="${MOGAN_ROOT}/TeXmacs"
DEBUG_BINARY="${MOGAN_ROOT}/build/linux/x86_64/debug/moganstem"
RELEASE_BINARY="${MOGAN_ROOT}/build/linux/x86_64/release/moganstem"
DEFAULT_HOST="${MOGAN_TEST_HOST:-127.0.0.1}"
DEFAULT_PSEUDO="${MOGAN_TEST_PSEUDO:-test-user}"
DEFAULT_NAME="${MOGAN_TEST_NAME:-Test User}"
DEFAULT_PASS="${MOGAN_TEST_PASS:-test-pass}"
DEFAULT_EMAIL="${MOGAN_TEST_EMAIL:-test@example.com}"
DEFAULT_FILE_PATH="${MOGAN_TEST_FILE_PATH:-/tmp/mogan-test-file-smoke.tm}"
DEFAULT_EXPORT_PATH="${MOGAN_TEST_EXPORT_PATH:-/tmp/mogan-test-export.html}"
TARGET_DIR="${MOGAN_TEST_TARGET_DIR:-$HOME/.config/mogan-test/targets}"
DEFAULT_RUNTIME_EXPR="(load \"$RUNTIME_SCRIPT\") (mogan-test-runtime-status)"
DEFAULT_SERVER_RUNTIME_EXPR="(load \"$SERVER_RUNTIME_SCRIPT\")"

source "$LIB_DIR/common.sh"
source "$LIB_DIR/runtime.sh"
source "$LIB_DIR/help.sh"
source "$LIB_DIR/targets.sh"
source "$LIB_DIR/scenarios.sh"
source "$LIB_DIR/handlers.sh"

require_gf_and_scheme_script

command_name="${1:-}"

case "$command_name" in
  build-client) handle_build_client "$@" ;;
  start-client) handle_start_client "$@" ;;
  start-server) handle_start_server "$@" ;;
  exec-internal) handle_exec_internal "$@" ;;
  target|session) handle_target_command "$@" ;;
  scenario) handle_scenario_command "$@" ;;
  batch) handle_batch_command "$@" ;;
  create-account) handle_create_account "$@" ;;
  connect) handle_connect "$@" ;;
  buffer-list|revert-buffer|close-buffer) handle_buffer_command "$@" ;;
  open-file|save-as|export-buffer) handle_open_save_export_command "$@" ;;
  set-main-style|set-document-language|add-style-package|remove-style-package)
    shift || true
    handle_value_remote_command "Style value is required" build_style_remote_command "$@"
    ;;
  set-page-medium|set-page-type|set-page-orientation)
    shift || true
    handle_value_remote_command "Page value is required" build_page_remote_command "$@"
    ;;
  search-set|replace-set)
    shift || true
    handle_value_remote_command "Search text is required" build_search_text_remote_command "$@"
    ;;
  search-state|search-next|search-prev|search-first|search-last|replace-one|replace-all)
    handle_search_action_command "$@"
    ;;
  ping|current-buffer|new-document|buffer-text|state|move-left|move-right|move-up|move-down|move-start|move-end|move-start-line|move-end-line|move-start-paragraph|move-end-paragraph|move-word-left|move-word-right|select-all|select-start|select-end|clear-selection|undo|redo|copy|cut|paste|clear-undo-history|insert-return|delete-left|delete-right|save-buffer)
    handle_simple_control_command "$@"
    ;;
  write-text) handle_write_text "$@" ;;
  move-to-line|move-to-column|insert-text|switch-buffer) handle_control_value_command "$@" ;;
  insert-equation|insert-inline-equation|insert-fraction|insert-sqrt|insert-sup|insert-sub|insert-bold|insert-italic|insert-code)
    handle_insert_basic_command "$@"
    ;;
  insert-matrix|insert-sum|insert-integral|insert-table|insert-link)
    handle_insert_complex_command "$@"
    ;;
  traces)
    shift || true
    show_traces
    ;;
  "") print_main_usage ; exit 0 ;;
  *)
    exec gf load "$SCHEME_SCRIPT" "$@"
    ;;
esac
