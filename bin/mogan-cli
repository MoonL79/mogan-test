#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCHEME_SCRIPT="${SCRIPT_DIR}/../src/cli/mogan-cli.scm"
RUNTIME_SCRIPT="${SCRIPT_DIR}/../src/cli/runtime/client.scm"
SERVER_RUNTIME_SCRIPT="${SCRIPT_DIR}/../src/cli/runtime/mogan-server-runtime.scm"
MOGAN_ROOT="/home/mingshen/git/mogan"
CONNECT_TRACE="/tmp/mogan-test-connect-trace.log"
SERVER_TRACE="/tmp/mogan-test-server-trace.log"
RESULT_FILE="/tmp/mogan-test-runtime-result.txt"
RUNTIME_OUTPUT="/tmp/mogan-test-runtime-output.log"
TEXMACS_PATH_DIR="${MOGAN_ROOT}/TeXmacs"
DEBUG_BINARY="${MOGAN_ROOT}/build/linux/x86_64/debug/moganstem"
RELEASE_BINARY="${MOGAN_ROOT}/build/linux/x86_64/release/moganstem"
DEFAULT_HOST="${MOGAN_TEST_HOST:-127.0.0.1}"
DEFAULT_PSEUDO="${MOGAN_TEST_PSEUDO:-test-user}"
DEFAULT_NAME="${MOGAN_TEST_NAME:-Test User}"
DEFAULT_PASS="${MOGAN_TEST_PASS:-test-pass}"
DEFAULT_EMAIL="${MOGAN_TEST_EMAIL:-test@example.com}"
DEFAULT_FILE_PATH="${MOGAN_TEST_FILE_PATH:-/tmp/mogan-test-file-smoke.tm}"
DEFAULT_EXPORT_PATH="${MOGAN_TEST_EXPORT_PATH:-/tmp/mogan-test-export.html}"
TARGET_DIR="${MOGAN_TEST_TARGET_DIR:-$HOME/.config/mogan-test/targets}"

if ! command -v gf >/dev/null 2>&1; then
  echo '{"status":"error","message":"Goldfish Scheme (gf) not found in PATH"}' >&2
  exit 1
fi

if [[ ! -f "$SCHEME_SCRIPT" ]]; then
  echo "{\"status\":\"error\",\"message\":\"Scheme script not found: $SCHEME_SCRIPT\"}" >&2
  exit 1
fi

resolve_mogan_binary() {
  if [[ -x "$DEBUG_BINARY" ]]; then
    printf '%s\n' "$DEBUG_BINARY"
    return 0
  fi
  if [[ -x "$RELEASE_BINARY" ]]; then
    printf '%s\n' "$RELEASE_BINARY"
    return 0
  fi
  return 1
}

print_runtime_result() {
  if [[ ! -f "$RESULT_FILE" ]]; then
    echo "status: error"
    echo "value: missing result file"
    return 1
  fi

  local status
  local value
  status="$(sed -n '1p' "$RESULT_FILE")"
  value="$(sed -n '2p' "$RESULT_FILE")"

  echo "status: ${status:-error}"
  echo "value: ${value:-missing runtime result}"

  [[ "$status" == "ok" ]]
}

scheme_escape() {
  local value="${1-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

target_is_valid_name() {
  local name="${1-}"
  [[ -n "$name" ]] && [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]]
}

target_file_path() {
  local name="${1-}"
  printf '%s/%s.target' "$TARGET_DIR" "$name"
}

target_ensure_dir() {
  mkdir -p "$TARGET_DIR"
}

target_save_profile() {
  local name="$1"
  local host="$2"
  local pseudo="$3"
  local display_name="$4"
  local passwd="$5"
  local email="$6"
  local path

  if ! target_is_valid_name "$name"; then
    echo "{\"status\":\"error\",\"message\":\"Invalid target name: $name\"}" >&2
    return 1
  fi

  target_ensure_dir
  path="$(target_file_path "$name")"
  (
    umask 077
    {
      printf 'host\t%s\n' "$host"
      printf 'pseudo\t%s\n' "$pseudo"
      printf 'name\t%s\n' "$display_name"
      printf 'passwd\t%s\n' "$passwd"
      printf 'email\t%s\n' "$email"
    } > "$path"
  )
}

target_field_value() {
  local path="$1"
  local key="$2"
  awk -F '\t' -v key="$key" '$1 == key { sub("^[^\t]+\t", "", $0); print; exit }' "$path"
}

target_read_profile() {
  local name="$1"
  local path
  local host
  local pseudo
  local display_name
  local passwd
  local email

  if ! target_is_valid_name "$name"; then
    echo "{\"status\":\"error\",\"message\":\"Invalid target name: $name\"}" >&2
    return 1
  fi

  path="$(target_file_path "$name")"
  if [[ ! -f "$path" ]]; then
    echo "{\"status\":\"error\",\"message\":\"Target not found: $name\"}" >&2
    return 1
  fi

  host="$(target_field_value "$path" host)"
  pseudo="$(target_field_value "$path" pseudo)"
  display_name="$(target_field_value "$path" name)"
  passwd="$(target_field_value "$path" passwd)"
  email="$(target_field_value "$path" email)"

  printf '%s\t%s\t%s\t%s\t%s\n' \
    "${host:-$DEFAULT_HOST}" \
    "${pseudo:-$DEFAULT_PSEUDO}" \
    "${display_name:-$DEFAULT_NAME}" \
    "${passwd:-$DEFAULT_PASS}" \
    "${email:-$DEFAULT_EMAIL}"
}

target_show_profile() {
  local name="$1"
  local path
  local host
  local pseudo
  local display_name
  local passwd
  local email

  if ! target_is_valid_name "$name"; then
    echo "{\"status\":\"error\",\"message\":\"Invalid target name: $name\"}" >&2
    return 1
  fi

  path="$(target_file_path "$name")"
  if [[ ! -f "$path" ]]; then
    echo "{\"status\":\"error\",\"message\":\"Target not found: $name\"}" >&2
    return 1
  fi

  host="$(target_field_value "$path" host)"
  pseudo="$(target_field_value "$path" pseudo)"
  display_name="$(target_field_value "$path" name)"
  passwd="$(target_field_value "$path" passwd)"
  email="$(target_field_value "$path" email)"

  printf 'name=%s\nhost=%s\npseudo=%s\ndisplay_name=%s\npasswd=%s\nemail=%s\n' \
    "$name" \
    "${host:-$DEFAULT_HOST}" \
    "${pseudo:-$DEFAULT_PSEUDO}" \
    "${display_name:-$DEFAULT_NAME}" \
    "${passwd:-$DEFAULT_PASS}" \
    "${email:-$DEFAULT_EMAIL}"
}

target_list_profiles() {
  target_ensure_dir
  find "$TARGET_DIR" -maxdepth 1 -type f -name '*.target' -printf '%f\n' 2>/dev/null | sed 's/\.target$//' | sort
}

target_run_command() {
  local name="$1"
  shift

  local profile
  local host
  local pseudo
  local display_name
  local passwd
  local email

  profile="$(target_read_profile "$name")" || return 1
  IFS=$'\t' read -r host pseudo display_name passwd email <<< "$profile"
  MOGAN_TEST_HOST="$host" \
  MOGAN_TEST_PSEUDO="$pseudo" \
  MOGAN_TEST_NAME="$display_name" \
  MOGAN_TEST_PASS="$passwd" \
  MOGAN_TEST_EMAIL="$email" \
  MOGAN_TEST_DRY_RUN="${MOGAN_TEST_DRY_RUN:-0}" \
  "$0" "$@"
}

batch_run_step() {
  local target_name="$1"
  local dry_run="${2:-false}"
  local step_index="${3:-0}"
  shift 3

  local -a step_args=("$@")

  if [[ ${#step_args[@]} -eq 0 ]]; then
    echo '{"status":"error","message":"Empty batch step"}' >&2
    return 1
  fi

  printf '== batch step %s: ' "$step_index" >&2
  printf '%q ' "${step_args[@]}" >&2
  printf '\n' >&2

  if [[ "$dry_run" == "true" ]]; then
    MOGAN_TEST_DRY_RUN=1 target_run_command "$target_name" "${step_args[@]}"
    return $?
  fi

  target_run_command "$target_name" "${step_args[@]}"
}

build_remote_runtime_expr() {
  local remote_command="$1"
  local server_name="${2:-127.0.0.1}"
  local pseudo="${3:-test-user}"
  local passwd="${4:-test-pass}"
  printf '(load "%s") (mogan-test-run-command "%s" "%s" "%s" '\''%s)' \
    "$RUNTIME_SCRIPT" \
    "$(scheme_escape "$server_name")" \
    "$(scheme_escape "$pseudo")" \
    "$(scheme_escape "$passwd")" \
    "$remote_command"
}

run_remote_runtime_command() {
  local remote_command="$1"
  local server_name="${2:-127.0.0.1}"
  local pseudo="${3:-test-user}"
  local passwd="${4:-test-pass}"
  local dry_run="${5:-}"
  local runtime_expr
  local binary_path

  runtime_expr="$(build_remote_runtime_expr "$remote_command" "$server_name" "$pseudo" "$passwd")"
  if [[ "$dry_run" == "--dry-run" ]]; then
    binary_path="$(resolve_mogan_binary || true)"
    if [[ -z "$binary_path" ]]; then
      echo '{"status":"error","message":"Built Mogan client not found. Run `./mogan-cli build-client` first."}' >&2
      exit 1
    fi

    printf 'cd %s && TEXMACS_PATH=%q %q -platform minimal -d -debug-bench -x %q\n' \
      "$MOGAN_ROOT" "$TEXMACS_PATH_DIR" "$binary_path" "$runtime_expr"
    exit 0
  fi

  run_runtime_command "$runtime_expr" "minimal"
}

show_file_section() {
  local label="$1"
  local path="$2"
  local mode="${3:-tail}"

  echo "== ${label} =="
  echo "path: ${path}"
  if [[ -f "$path" ]]; then
    echo "status: present"
    if [[ "$mode" == "cat" ]]; then
      cat "$path"
    else
      tail -n 120 "$path"
    fi
  else
    echo "status: missing"
  fi
  echo
}

show_traces() {
  show_file_section "connect-trace" "$CONNECT_TRACE"
  show_file_section "server-trace" "$SERVER_TRACE"
  show_file_section "runtime-result" "$RESULT_FILE" cat
  show_file_section "runtime-output" "$RUNTIME_OUTPUT"
}

run_runtime_command() {
  local runtime_expr="$1"
  local platform="${2:-minimal}"
  local binary_path

  binary_path="$(resolve_mogan_binary || true)"
  if [[ -z "$binary_path" ]]; then
    echo '{"status":"error","message":"Built Mogan client not found. Run `./mogan-cli build-client` first."}' >&2
    exit 1
  fi

  : > "$CONNECT_TRACE"
  : > "$RESULT_FILE"

  cd "$MOGAN_ROOT"
  env TEXMACS_PATH="$TEXMACS_PATH_DIR" "$binary_path" -platform "$platform" -d -debug-bench -x "$runtime_expr" >"$RUNTIME_OUTPUT" 2>&1 || true
  print_runtime_result
}

command_name="${1:-}"

default_runtime_expr="(load \"$RUNTIME_SCRIPT\") (mogan-test-runtime-status)"
default_server_runtime_expr="(load \"$SERVER_RUNTIME_SCRIPT\")"

case "$command_name" in
  build-client)
    shift || true
    cd "$MOGAN_ROOT"
    exec xmake b stem "$@"
    ;;
  start-client)
    shift || true
    if [[ "${1:-}" == "--server" ]] || [[ "${1:-}" == "--dry-run" ]] || [[ "${1:-}" == "--platform" ]]; then
      binary_path="$(resolve_mogan_binary || true)"
      if [[ -z "$binary_path" ]]; then
        echo '{"status":"error","message":"Built Mogan client not found. Run `./mogan-cli build-client` first."}' >&2
        exit 1
      fi

      platform=""
      runtime_expr="$default_server_runtime_expr"
      with_server="false"
      dry_run="false"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --server)
            with_server="true"
            ;;
          --platform)
            platform="${2:-}"
            shift
            ;;
          --without-runtime)
            runtime_expr=""
            ;;
          --dry-run)
            dry_run="true"
            ;;
        esac
        shift
      done

      cmd=(env "TEXMACS_PATH=$TEXMACS_PATH_DIR" "$binary_path")
      if [[ -n "$platform" ]]; then
        cmd+=(-platform "$platform")
      fi
      cmd+=(-d -debug-bench)
      if [[ "$with_server" == "true" ]]; then
        cmd+=(-server)
      fi
      if [[ -n "$runtime_expr" ]]; then
        cmd+=(-x "$runtime_expr")
      fi

      if [[ "$dry_run" == "true" ]]; then
        printf 'cd %s &&' "$MOGAN_ROOT"
        printf ' %q' "${cmd[@]}"
        printf '\n'
        exit 0
      fi

      cd "$MOGAN_ROOT"
      exec "${cmd[@]}"
    fi

    cd "$MOGAN_ROOT"
    exec xmake r stem "$@"
    ;;
  start-server)
    shift || true
    exec "$0" start-client --server "$@"
    ;;
  exec-internal)
    shift || true
    binary_path="$(resolve_mogan_binary || true)"
    if [[ -z "$binary_path" ]]; then
      echo '{"status":"error","message":"Built Mogan client not found. Run `./mogan-cli build-client` first."}' >&2
      exit 1
    fi
    runtime_expr="${1:-}"
    if [[ "$runtime_expr" == "--dry-run" ]] || [[ -z "$runtime_expr" ]]; then
      runtime_expr="$default_runtime_expr"
    fi
    if [[ "${2:-}" == "--dry-run" ]] || [[ "${1:-}" == "--dry-run" ]]; then
      printf 'cd %s && TEXMACS_PATH=%q %q -platform minimal -d -debug-bench -x %q\n' "$MOGAN_ROOT" "$TEXMACS_PATH_DIR" "$binary_path" "$runtime_expr"
      exit 0
    fi
    run_runtime_command "$runtime_expr" "minimal"
    ;;
  target|session)
    shift || true
    target_action="${1:-}"
    case "$target_action" in
      save|add|open)
        target_name="${2:-}"
        server_name="${3:-$DEFAULT_HOST}"
        pseudo="${4:-$DEFAULT_PSEUDO}"
        display_name="${5:-$DEFAULT_NAME}"
        passwd="${6:-$DEFAULT_PASS}"
        email="${7:-$DEFAULT_EMAIL}"
        if [[ -z "$target_name" ]]; then
          echo '{"status":"error","message":"Target name is required"}' >&2
          exit 1
        fi
        target_save_profile "$target_name" "$server_name" "$pseudo" "$display_name" "$passwd" "$email"
        ;;
      show)
        target_name="${2:-}"
        if [[ -z "$target_name" ]]; then
          echo '{"status":"error","message":"Target name is required"}' >&2
          exit 1
        fi
        target_show_profile "$target_name"
        ;;
      list)
        target_list_profiles
        ;;
      delete|remove)
        target_name="${2:-}"
        if [[ -z "$target_name" ]]; then
          echo '{"status":"error","message":"Target name is required"}' >&2
          exit 1
        fi
        if ! target_is_valid_name "$target_name"; then
          echo "{\"status\":\"error\",\"message\":\"Invalid target name: $target_name\"}" >&2
          exit 1
        fi
        rm -f "$(target_file_path "$target_name")"
        ;;
      run|use|exec)
        target_name="${2:-}"
        if [[ -z "$target_name" ]]; then
          echo '{"status":"error","message":"Target name is required"}' >&2
          exit 1
        fi
        if [[ $# -lt 3 ]]; then
          echo '{"status":"error","message":"Target run requires a command"}' >&2
          exit 1
        fi
        shift 2
        target_run_command "$target_name" "$@"
        ;;
      "")
        cat <<'EOF'
Usage: mogan-cli target <save|show|list|delete|run> [...]
EOF
        exit 1
        ;;
      *)
        echo "{\"status\":\"error\",\"message\":\"Unknown target action: $target_action\"}" >&2
        exit 1
        ;;
    esac
    ;;
  scenario)
    shift || true
    scenario_name="${1:-}"
    case "$scenario_name" in
      list)
        cat <<'EOF'
smoke-edit
batch-smoke
file-smoke
export-smoke
style-smoke
layout-smoke
search-smoke
history-smoke
clipboard-smoke
EOF
        ;;
      smoke-edit)
        shift || true
        if [[ "${1:-}" == "--dry-run" ]]; then
          set -- "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "--dry-run"
        fi
        server_name="${1:-$DEFAULT_HOST}"
        pseudo="${2:-$DEFAULT_PSEUDO}"
        passwd="${3:-$DEFAULT_PASS}"
        remote_command="(mogan-test-smoke-edit)"
        run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "${4:-}"
        ;;
      batch-smoke)
        shift || true
        target_name="smoke"
        dry_run_flag=""
        if [[ $# -gt 0 ]]; then
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry_run_flag="--dry-run"
          else
            target_name="$1"
            shift || true
            if [[ "${1:-}" == "--dry-run" ]]; then
              dry_run_flag="--dry-run"
            fi
          fi
        fi
        batch_args=(batch "$target_name")
        if [[ -n "$dry_run_flag" ]]; then
          batch_args+=("$dry_run_flag")
        fi
        batch_args+=(-- new-document -- write-text "hello from mogan-test" -- move-end -- insert-text "!" -- buffer-text)
        exec "$0" "${batch_args[@]}"
        ;;
      file-smoke)
        shift || true
        target_name="smoke"
        file_path="$DEFAULT_FILE_PATH"
        dry_run_flag=""
        if [[ $# -gt 0 ]]; then
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry_run_flag="--dry-run"
          else
            target_name="$1"
            shift || true
            if [[ $# -gt 0 ]] && [[ "${1:-}" != "--dry-run" ]]; then
              file_path="$1"
              shift || true
            fi
            if [[ "${1:-}" == "--dry-run" ]]; then
              dry_run_flag="--dry-run"
            fi
          fi
        fi
        batch_args=(batch "$target_name")
        if [[ -n "$dry_run_flag" ]]; then
          batch_args+=("$dry_run_flag")
        fi
        batch_args+=(-- new-document -- write-text "file smoke" -- save-as "$file_path" -- insert-text "!" -- revert-buffer -- buffer-text -- new-document -- close-buffer -- open-file "$file_path" -- buffer-text -- buffer-list)
        exec "$0" "${batch_args[@]}"
        ;;
      export-smoke)
        shift || true
        target_name="smoke"
        export_path="$DEFAULT_EXPORT_PATH"
        dry_run_flag=""
        if [[ $# -gt 0 ]]; then
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry_run_flag="--dry-run"
          else
            target_name="$1"
            shift || true
            if [[ $# -gt 0 ]] && [[ "${1:-}" != "--dry-run" ]]; then
              export_path="$1"
              shift || true
            fi
            if [[ "${1:-}" == "--dry-run" ]]; then
              dry_run_flag="--dry-run"
            fi
          fi
        fi
        batch_args=(batch "$target_name")
        if [[ -n "$dry_run_flag" ]]; then
          batch_args+=("$dry_run_flag")
        fi
        batch_args+=(-- new-document -- write-text "export smoke" -- export-buffer "$export_path")
        exec "$0" "${batch_args[@]}"
        ;;
      style-smoke)
        shift || true
        target_name="smoke"
        dry_run_flag=""
        if [[ $# -gt 0 ]]; then
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry_run_flag="--dry-run"
          else
            target_name="$1"
            shift || true
            if [[ "${1:-}" == "--dry-run" ]]; then
              dry_run_flag="--dry-run"
            fi
          fi
        fi
        batch_args=(batch "$target_name")
        if [[ -n "$dry_run_flag" ]]; then
          batch_args+=("$dry_run_flag")
        fi
        batch_args+=(-- new-document -- set-main-style article -- set-document-language chinese -- add-style-package number-us -- remove-style-package number-us -- state)
        exec "$0" "${batch_args[@]}"
        ;;
      layout-smoke)
        shift || true
        target_name="smoke"
        dry_run_flag=""
        if [[ $# -gt 0 ]]; then
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry_run_flag="--dry-run"
          else
            target_name="$1"
            shift || true
            if [[ "${1:-}" == "--dry-run" ]]; then
              dry_run_flag="--dry-run"
            fi
          fi
        fi
        batch_args=(batch "$target_name")
        if [[ -n "$dry_run_flag" ]]; then
          batch_args+=("$dry_run_flag")
        fi
        batch_args+=(-- new-document -- set-page-medium papyrus -- set-page-type letter -- set-page-orientation landscape -- state)
        exec "$0" "${batch_args[@]}"
        ;;
      search-smoke)
        shift || true
        target_name="smoke"
        dry_run_flag=""
        if [[ $# -gt 0 ]]; then
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry_run_flag="--dry-run"
          else
            target_name="$1"
            shift || true
            if [[ "${1:-}" == "--dry-run" ]]; then
              dry_run_flag="--dry-run"
            fi
          fi
        fi
        batch_args=(batch "$target_name")
        if [[ -n "$dry_run_flag" ]]; then
          batch_args+=("$dry_run_flag")
        fi
        batch_args+=(-- new-document -- write-text "alpha beta alpha" -- search-set alpha -- search-state -- search-next -- search-prev -- search-last -- search-first -- replace-set gamma -- search-state -- replace-one -- replace-all -- buffer-text)
        exec "$0" "${batch_args[@]}"
        ;;
      history-smoke)
        shift || true
        target_name="smoke"
        dry_run_flag=""
        if [[ $# -gt 0 ]]; then
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry_run_flag="--dry-run"
          else
            target_name="$1"
            shift || true
            if [[ "${1:-}" == "--dry-run" ]]; then
              dry_run_flag="--dry-run"
            fi
          fi
        fi
        batch_args=(batch "$target_name")
        if [[ -n "$dry_run_flag" ]]; then
          batch_args+=("$dry_run_flag")
        fi
        batch_args+=(-- new-document -- insert-text "hello" -- undo -- redo -- clear-undo-history -- state)
        exec "$0" "${batch_args[@]}"
        ;;
      clipboard-smoke)
        shift || true
        target_name="smoke"
        dry_run_flag=""
        if [[ $# -gt 0 ]]; then
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry_run_flag="--dry-run"
          else
            target_name="$1"
            shift || true
            if [[ "${1:-}" == "--dry-run" ]]; then
              dry_run_flag="--dry-run"
            fi
          fi
        fi
        batch_args=(batch "$target_name")
        if [[ -n "$dry_run_flag" ]]; then
          batch_args+=("$dry_run_flag")
        fi
        batch_args+=(-- new-document -- write-text "hello" -- select-all -- copy -- new-document -- paste -- state)
        exec "$0" "${batch_args[@]}"
        ;;
      "")
        cat <<'EOF'
Usage: mogan-cli scenario <list|smoke-edit|batch-smoke|file-smoke|export-smoke|style-smoke|layout-smoke|search-smoke|history-smoke|clipboard-smoke> [args...]
EOF
        exit 1
        ;;
      *)
        echo "{\"status\":\"error\",\"message\":\"Unknown scenario: $scenario_name\"}" >&2
        exit 1
        ;;
    esac
    ;;
  batch)
    shift || true
    target_name="${1:-}"
    if [[ -z "$target_name" ]]; then
      echo '{"status":"error","message":"Target name is required"}' >&2
      exit 1
    fi
    shift || true
    batch_dry_run="false"
    if [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]] || [[ "${1:-}" == "--dry-run" ]]; then
      batch_dry_run="true"
      shift || true
    fi
    if [[ "${1:-}" == "--" ]]; then
      shift || true
    fi
    if [[ $# -eq 0 ]]; then
      echo '{"status":"error","message":"Batch requires at least one step"}' >&2
      exit 1
    fi
    current_step=()
    step_index=0
    while [[ $# -gt 0 ]]; do
      if [[ "$1" == "--" ]]; then
        if [[ ${#current_step[@]} -gt 0 ]]; then
          step_index=$((step_index + 1))
          batch_run_step "$target_name" "$batch_dry_run" "$step_index" "${current_step[@]}"
          current_step=()
        fi
      else
        current_step+=("$1")
      fi
      shift || true
    done
    if [[ ${#current_step[@]} -gt 0 ]]; then
      step_index=$((step_index + 1))
      batch_run_step "$target_name" "$batch_dry_run" "$step_index" "${current_step[@]}"
    fi
    ;;
  create-account)
    shift || true
    if [[ "${1:-}" == "--dry-run" ]]; then
      set -- "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_NAME" "$DEFAULT_PASS" "$DEFAULT_EMAIL" "--dry-run"
    fi
    server_name="${1:-$DEFAULT_HOST}"
    pseudo="${2:-$DEFAULT_PSEUDO}"
    name="${3:-$DEFAULT_NAME}"
    passwd="${4:-$DEFAULT_PASS}"
    email="${5:-$DEFAULT_EMAIL}"
    runtime_expr="(load \"$RUNTIME_SCRIPT\") (mogan-test-create-account \"$(scheme_escape "$server_name")\" \"$(scheme_escape "$pseudo")\" \"$(scheme_escape "$name")\" \"$(scheme_escape "$passwd")\" \"$(scheme_escape "$email")\")"
    if [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]] || [[ "${6:-}" == "--dry-run" ]] || [[ "${1:-}" == "--dry-run" ]]; then
      binary_path="$(resolve_mogan_binary || true)"
      if [[ -z "$binary_path" ]]; then
        echo '{"status":"error","message":"Built Mogan client not found. Run `./mogan-cli build-client` first."}' >&2
        exit 1
      fi
      printf 'cd %s && TEXMACS_PATH=%q %q -platform minimal -d -debug-bench -x %q\n' \
        "$MOGAN_ROOT" "$TEXMACS_PATH_DIR" "$binary_path" "$runtime_expr"
      exit 0
    fi
    run_runtime_command "$runtime_expr" "minimal"
    ;;
  connect)
    shift || true
    if [[ "${1:-}" == "--dry-run" ]]; then
      set -- "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "--dry-run"
    fi
    server_name="${1:-$DEFAULT_HOST}"
    pseudo="${2:-$DEFAULT_PSEUDO}"
    passwd="${3:-$DEFAULT_PASS}"
    runtime_expr="(load \"$RUNTIME_SCRIPT\") (mogan-test-connect \"$(scheme_escape "$server_name")\" \"$(scheme_escape "$pseudo")\" \"$(scheme_escape "$passwd")\")"
    if [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]] || [[ "${4:-}" == "--dry-run" ]] || [[ "${1:-}" == "--dry-run" ]]; then
      binary_path="$(resolve_mogan_binary || true)"
      if [[ -z "$binary_path" ]]; then
        echo '{"status":"error","message":"Built Mogan client not found. Run `./mogan-cli build-client` first."}' >&2
        exit 1
      fi
      printf 'cd %s && TEXMACS_PATH=%q %q -platform minimal -d -debug-bench -x %q\n' \
        "$MOGAN_ROOT" "$TEXMACS_PATH_DIR" "$binary_path" "$runtime_expr"
      exit 0
    fi
    run_runtime_command "$runtime_expr" "minimal"
    ;;
  buffer-list|revert-buffer|close-buffer)
    shift || true
    dry_run_flag="${4:-}"
    if [[ "${1:-}" == "--dry-run" ]]; then
      set -- "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "--dry-run"
      dry_run_flag="--dry-run"
    elif [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]]; then
      dry_run_flag="--dry-run"
    fi
    server_name="${1:-$DEFAULT_HOST}"
    pseudo="${2:-$DEFAULT_PSEUDO}"
    passwd="${3:-$DEFAULT_PASS}"
    case "$command_name" in
      buffer-list)
        remote_command="(mogan-test-buffer-list)"
        ;;
      revert-buffer)
        remote_command="(mogan-test-revert-buffer)"
        ;;
      close-buffer)
        remote_command="(mogan-test-close-buffer)"
        ;;
    esac
    run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "$dry_run_flag"
    ;;
  open-file|save-as|export-buffer)
    shift || true
    dry_run_flag=""
    default_path="$DEFAULT_FILE_PATH"
    if [[ "$command_name" == "export-buffer" ]]; then
      default_path="$DEFAULT_EXPORT_PATH"
    fi
    if [[ "${1:-}" == "--dry-run" ]]; then
      file_path="$default_path"
      dry_run_flag="--dry-run"
    else
      file_path="${1:-}"
      if [[ -z "$file_path" ]]; then
        if [[ "$command_name" == "export-buffer" ]]; then
          echo '{"status":"error","message":"Export path is required"}' >&2
        else
          echo '{"status":"error","message":"File path is required"}' >&2
        fi
        exit 1
      fi
      if [[ "${2:-}" == "--dry-run" ]]; then
        dry_run_flag="--dry-run"
      fi
    fi
    if [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]]; then
      dry_run_flag="--dry-run"
    fi
    case "$command_name" in
      open-file)
        remote_command="(mogan-test-open-file \"$(scheme_escape "$file_path")\")"
        ;;
      save-as)
        remote_command="(mogan-test-save-as \"$(scheme_escape "$file_path")\")"
        ;;
      export-buffer)
        remote_command="(mogan-test-export-buffer \"$(scheme_escape "$file_path")\")"
        ;;
    esac
    run_remote_runtime_command "$remote_command" "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "$dry_run_flag"
    ;;
  set-main-style|set-document-language|add-style-package|remove-style-package)
    shift || true
    dry_run_flag=""
    if [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]] || [[ "${2:-}" == "--dry-run" ]] || [[ "${5:-}" == "--dry-run" ]]; then
      dry_run_flag="--dry-run"
    fi
    if [[ $# -eq 1 ]]; then
      server_name="$DEFAULT_HOST"
      pseudo="$DEFAULT_PSEUDO"
      passwd="$DEFAULT_PASS"
      value="${1:-}"
    elif [[ $# -eq 2 ]] && [[ "${2:-}" == "--dry-run" ]]; then
      server_name="$DEFAULT_HOST"
      pseudo="$DEFAULT_PSEUDO"
      passwd="$DEFAULT_PASS"
      value="${1:-}"
    else
      if [[ $# -lt 4 ]]; then
        echo '{"status":"error","message":"Style value is required"}' >&2
        exit 1
      fi
      server_name="${1:-$DEFAULT_HOST}"
      pseudo="${2:-$DEFAULT_PSEUDO}"
      passwd="${3:-$DEFAULT_PASS}"
      value="${4:-}"
    fi
    if [[ "$value" == "--dry-run" ]]; then
      echo '{"status":"error","message":"Style value is required"}' >&2
      exit 1
    fi
    case "$command_name" in
      set-main-style)
        remote_command="(mogan-test-set-main-style \"$(scheme_escape "$value")\")"
        ;;
      set-document-language)
        remote_command="(mogan-test-set-document-language \"$(scheme_escape "$value")\")"
        ;;
      add-style-package)
        remote_command="(mogan-test-add-style-package \"$(scheme_escape "$value")\")"
        ;;
      remove-style-package)
        remote_command="(mogan-test-remove-style-package \"$(scheme_escape "$value")\")"
        ;;
    esac
    run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "$dry_run_flag"
    ;;
  set-page-medium|set-page-type|set-page-orientation)
    shift || true
    dry_run_flag=""
    if [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]] || [[ "${2:-}" == "--dry-run" ]] || [[ "${5:-}" == "--dry-run" ]]; then
      dry_run_flag="--dry-run"
    fi
    if [[ $# -eq 1 ]]; then
      server_name="$DEFAULT_HOST"
      pseudo="$DEFAULT_PSEUDO"
      passwd="$DEFAULT_PASS"
      value="${1:-}"
    elif [[ $# -eq 2 ]] && [[ "${2:-}" == "--dry-run" ]]; then
      server_name="$DEFAULT_HOST"
      pseudo="$DEFAULT_PSEUDO"
      passwd="$DEFAULT_PASS"
      value="${1:-}"
    else
      if [[ $# -lt 4 ]]; then
        echo '{"status":"error","message":"Page value is required"}' >&2
        exit 1
      fi
      server_name="${1:-$DEFAULT_HOST}"
      pseudo="${2:-$DEFAULT_PSEUDO}"
      passwd="${3:-$DEFAULT_PASS}"
      value="${4:-}"
    fi
    if [[ "$value" == "--dry-run" ]]; then
      echo '{"status":"error","message":"Page value is required"}' >&2
      exit 1
    fi
    case "$command_name" in
      set-page-medium)
        remote_command="(mogan-test-set-page-medium \"$(scheme_escape "$value")\")"
        ;;
      set-page-type)
        remote_command="(mogan-test-set-page-type \"$(scheme_escape "$value")\")"
        ;;
      set-page-orientation)
        remote_command="(mogan-test-set-page-orientation \"$(scheme_escape "$value")\")"
        ;;
    esac
    run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "$dry_run_flag"
    ;;
  search-set|replace-set)
    shift || true
    dry_run_flag=""
    if [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]] || [[ "${2:-}" == "--dry-run" ]] || [[ "${5:-}" == "--dry-run" ]]; then
      dry_run_flag="--dry-run"
    fi
    if [[ $# -eq 1 ]]; then
      server_name="$DEFAULT_HOST"
      pseudo="$DEFAULT_PSEUDO"
      passwd="$DEFAULT_PASS"
      text="${1:-}"
    elif [[ $# -eq 2 ]] && [[ "${2:-}" == "--dry-run" ]]; then
      server_name="$DEFAULT_HOST"
      pseudo="$DEFAULT_PSEUDO"
      passwd="$DEFAULT_PASS"
      text="${1:-}"
    else
      if [[ $# -lt 4 ]]; then
        echo '{"status":"error","message":"Search text is required"}' >&2
        exit 1
      fi
      server_name="${1:-$DEFAULT_HOST}"
      pseudo="${2:-$DEFAULT_PSEUDO}"
      passwd="${3:-$DEFAULT_PASS}"
      text="${4:-}"
    fi
    if [[ "$text" == "--dry-run" ]]; then
      echo '{"status":"error","message":"Search text is required"}' >&2
      exit 1
    fi
    case "$command_name" in
      search-set)
        remote_command="(mogan-test-search-set \"$(scheme_escape "$text")\")"
        ;;
      replace-set)
        remote_command="(mogan-test-replace-set \"$(scheme_escape "$text")\")"
        ;;
    esac
    run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "$dry_run_flag"
    ;;
  search-state|search-next|search-prev|search-first|search-last|replace-one|replace-all)
    shift || true
    dry_run_flag="${4:-}"
    if [[ "${1:-}" == "--dry-run" ]]; then
      set -- "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "--dry-run"
      dry_run_flag="--dry-run"
    elif [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]]; then
      dry_run_flag="--dry-run"
    fi
    server_name="${1:-$DEFAULT_HOST}"
    pseudo="${2:-$DEFAULT_PSEUDO}"
    passwd="${3:-$DEFAULT_PASS}"
    case "$command_name" in
      search-state)
        remote_command="(mogan-test-search-state)"
        ;;
      search-next)
        remote_command="(mogan-test-search-next)"
        ;;
      search-prev)
        remote_command="(mogan-test-search-prev)"
        ;;
      search-first)
        remote_command="(mogan-test-search-first)"
        ;;
      search-last)
        remote_command="(mogan-test-search-last)"
        ;;
      replace-one)
        remote_command="(mogan-test-replace-one)"
        ;;
      replace-all)
        remote_command="(mogan-test-replace-all)"
        ;;
    esac
    run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "$dry_run_flag"
    ;;
  ping|current-buffer|new-document|buffer-text|state|move-left|move-right|move-up|move-down|move-start|move-end|move-start-line|move-end-line|move-start-paragraph|move-end-paragraph|move-word-left|move-word-right|select-all|select-start|select-end|clear-selection|undo|redo|copy|cut|paste|clear-undo-history|insert-return|delete-left|delete-right|save-buffer)
    shift || true
    dry_run_flag="${4:-}"
    if [[ "${1:-}" == "--dry-run" ]]; then
      set -- "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "--dry-run"
      dry_run_flag="--dry-run"
    elif [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]]; then
      dry_run_flag="--dry-run"
    fi
    server_name="${1:-$DEFAULT_HOST}"
    pseudo="${2:-$DEFAULT_PSEUDO}"
    passwd="${3:-$DEFAULT_PASS}"
    case "$command_name" in
      ping)
        remote_command="(mogan-test-ping)"
        ;;
      current-buffer)
        remote_command="(mogan-test-current-buffer)"
        ;;
      new-document)
        remote_command="(mogan-test-new-document)"
        ;;
      buffer-text)
        remote_command="(mogan-test-buffer-text)"
        ;;
      state)
        remote_command="(mogan-test-state)"
        ;;
      move-left)
        remote_command="(mogan-test-move-left)"
        ;;
      move-right)
        remote_command="(mogan-test-move-right)"
        ;;
      move-up)
        remote_command="(mogan-test-move-up)"
        ;;
      move-down)
        remote_command="(mogan-test-move-down)"
        ;;
      move-start)
        remote_command="(mogan-test-move-start)"
        ;;
      move-end)
        remote_command="(mogan-test-move-end)"
        ;;
      move-start-line)
        remote_command="(mogan-test-move-start-line)"
        ;;
      move-end-line)
        remote_command="(mogan-test-move-end-line)"
        ;;
      move-start-paragraph)
        remote_command="(mogan-test-move-start-paragraph)"
        ;;
      move-end-paragraph)
        remote_command="(mogan-test-move-end-paragraph)"
        ;;
      move-word-left)
        remote_command="(mogan-test-move-word-left)"
        ;;
      move-word-right)
        remote_command="(mogan-test-move-word-right)"
        ;;
      select-all)
        remote_command="(mogan-test-select-all)"
        ;;
      select-start)
        remote_command="(mogan-test-select-start)"
        ;;
      select-end)
        remote_command="(mogan-test-select-end)"
        ;;
      clear-selection)
        remote_command="(mogan-test-clear-selection)"
        ;;
      undo)
        remote_command="(mogan-test-history-undo)"
        ;;
      redo)
        remote_command="(mogan-test-history-redo)"
        ;;
      copy)
        remote_command="(mogan-test-clipboard-copy)"
        ;;
      cut)
        remote_command="(mogan-test-clipboard-cut)"
        ;;
      paste)
        remote_command="(mogan-test-clipboard-paste)"
        ;;
      clear-undo-history)
        remote_command="(mogan-test-clear-history)"
        ;;
      insert-return)
        remote_command="(mogan-test-insert-return)"
        ;;
      delete-left)
        remote_command="(mogan-test-delete-left)"
        ;;
      delete-right)
        remote_command="(mogan-test-delete-right)"
        ;;
      save-buffer)
        remote_command="(mogan-test-save-buffer)"
        ;;
    esac
    run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "$dry_run_flag"
    ;;
  write-text)
    shift || true
    dry_run_flag="${5:-}"
    if [[ "${1:-}" == "--dry-run" ]]; then
      set -- "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "hello from mogan-test" "--dry-run"
      dry_run_flag="--dry-run"
    elif [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]]; then
      dry_run_flag="--dry-run"
    fi
    if [[ $# -le 1 ]]; then
      server_name="$DEFAULT_HOST"
      pseudo="$DEFAULT_PSEUDO"
      passwd="$DEFAULT_PASS"
      text="${1:-hello from mogan-test}"
    else
      server_name="${1:-$DEFAULT_HOST}"
      pseudo="${2:-$DEFAULT_PSEUDO}"
      passwd="${3:-$DEFAULT_PASS}"
      text="${4:-hello from mogan-test}"
    fi
    remote_command="(mogan-test-write-text \"$(scheme_escape "$text")\")"
    run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "$dry_run_flag"
    ;;
  move-to-line|move-to-column|insert-text|switch-buffer)
    shift || true
    case "$command_name" in
      move-to-line|move-to-column)
        dry_run_flag="${5:-}"
        if [[ "${1:-}" == "--dry-run" ]]; then
          set -- "1" "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "--dry-run"
          dry_run_flag="--dry-run"
        elif [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]]; then
          dry_run_flag="--dry-run"
        fi
        control_value="${1:-1}"
        server_name="${2:-$DEFAULT_HOST}"
        pseudo="${3:-$DEFAULT_PSEUDO}"
        passwd="${4:-$DEFAULT_PASS}"
        ;;
      insert-text)
        dry_run_flag="${5:-}"
        if [[ "${1:-}" == "--dry-run" ]]; then
          set -- "hello from mogan-test" "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "--dry-run"
          dry_run_flag="--dry-run"
        elif [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]]; then
          dry_run_flag="--dry-run"
        fi
        control_value="${1:-hello from mogan-test}"
        server_name="${2:-$DEFAULT_HOST}"
        pseudo="${3:-$DEFAULT_PSEUDO}"
        passwd="${4:-$DEFAULT_PASS}"
        ;;
      switch-buffer)
        dry_run_flag="${5:-}"
        if [[ "${1:-}" == "--dry-run" ]]; then
          set -- "tmfs://dummy" "$DEFAULT_HOST" "$DEFAULT_PSEUDO" "$DEFAULT_PASS" "--dry-run"
          dry_run_flag="--dry-run"
        elif [[ "${MOGAN_TEST_DRY_RUN:-0}" == "1" ]]; then
          dry_run_flag="--dry-run"
        fi
        control_value="${1:-tmfs://dummy}"
        server_name="${2:-$DEFAULT_HOST}"
        pseudo="${3:-$DEFAULT_PSEUDO}"
        passwd="${4:-$DEFAULT_PASS}"
        ;;
    esac
    case "$command_name" in
      move-to-line)
        remote_command="(mogan-test-move-to-line \"$(scheme_escape "$control_value")\")"
        ;;
      move-to-column)
        remote_command="(mogan-test-move-to-column \"$(scheme_escape "$control_value")\")"
        ;;
      insert-text)
        remote_command="(mogan-test-insert-text \"$(scheme_escape "$control_value")\")"
        ;;
      switch-buffer)
        remote_command="(mogan-test-switch-buffer \"$(scheme_escape "$control_value")\")"
        ;;
    esac
    run_remote_runtime_command "$remote_command" "$server_name" "$pseudo" "$passwd" "$dry_run_flag"
    ;;
  traces)
    shift || true
    show_traces
    ;;
  "")
    cat <<'EOF'
Usage: mogan-cli <command> [args...]
Commands:
  status         - Show current runtime and connection status as JSON
  workflow       - Show the required Mogan startup workflow
  build-client   - Build Mogan with `xmake b stem`
  start-client   - Start a full Mogan client with `xmake r stem`
  start-server   - Start a connectable Mogan client with `moganstem -server`
  exec-internal  - Start Mogan and execute internal Scheme via `-x`
  create-account - Create a test account through the remote service layer
  connect        - Attempt remote-login inside the runtime
  ping           - Run the server-side `mogan-test-ping` service
  current-buffer - Query the current buffer from the running Mogan instance
  new-document   - Create a new document through the running Mogan instance
  write-text     - Replace the current buffer with plain text content
  buffer-text    - Read back the current buffer text content
  state          - Inspect buffer, cursor, selection, and text state
  move-*         - Cursor movement primitives
  select-*       - Selection primitives
  undo/redo      - History primitives
  copy/cut/paste - Clipboard primitives
  clear-undo-history - Reset the current edit history
  insert-text    - Insert text at the cursor
  insert-return  - Insert a raw return
  delete-*       - Delete at the cursor
  save-buffer    - Save the current buffer
  switch-buffer  - Switch to another buffer
  search-state   - Inspect search and replace state
  search-set     - Set the current search query
  search-next    - Move to the next search match
  search-prev    - Move to the previous search match
  search-first   - Move to the first search match
  search-last    - Move to the last search match
  replace-set    - Set the current replacement text
  replace-one    - Replace the current match once
  replace-all    - Replace all remaining matches
  buffer-list    - List open buffers with titles and modified state
  open-file      - Load a file into the current session
  save-as        - Save the current buffer under a new name
  revert-buffer  - Revert the current buffer from disk
  close-buffer   - Close the current buffer immediately
  batch          - Run a sequence of control commands against one target
  target         - Save, show, list, delete, or use a named target profile
  session        - Alias for target
  scenario       - Run a named batch workflow
  scenario batch-smoke - Run a target-backed low-level smoke workflow
  scenario file-smoke - Run a target-backed file lifecycle workflow
  scenario search-smoke - Run a target-backed search/replace workflow
  scenario history-smoke - Run a target-backed undo/redo workflow
  scenario clipboard-smoke - Run a target-backed clipboard workflow
  traces         - Print the current connect/server trace bundle
EOF
    exit 0
    ;;
  *)
    exec gf load "$SCHEME_SCRIPT" "$@"
    ;;
esac
